<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <system.diagnostics>
        <sources>
            <!-- This section defines the logging configuration for My.Application.Log -->
            <source name="DefaultSource" switchName="DefaultSwitch">
                <listeners>
                    <add name="FileLog"/>
                    <!-- Uncomment the below section to write to the Application Event Log -->
                    <!--<add name="EventLog"/>-->
                </listeners>
            </source>
        </sources>
        <switches>
            <add name="DefaultSwitch" value="Information" />
        </switches>
        <sharedListeners>
            <add name="FileLog"
                 type="Microsoft.VisualBasic.Logging.FileLogTraceListener, Microsoft.VisualBasic, Version=8.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a, processorArchitecture=MSIL"
                 initializeData="FileLogWriter"/>
            <!-- Uncomment the below section and replace APPLICATION_NAME with the name of your application to write to the Application Event Log -->
            <!--<add name="EventLog" type="System.Diagnostics.EventLogTraceListener" initializeData="APPLICATION_NAME"/> -->
        </sharedListeners>
    </system.diagnostics>
    <system.serviceModel>
        <bindings>
            <basicHttpBinding>
                <binding name="PortalServiceSoap">
                    <security mode="Transport" />
                </binding>
                <binding name="PortalServiceSoap1" />
                <binding name="BusinessServiceSoap">
                    <security mode="Transport" />
                </binding>
                <binding name="BusinessServiceSoap1" />
                <binding name="PublishServiceSoap">
                    <security mode="Transport" />
                </binding>
                <binding name="PublishServiceSoap1" />
            </basicHttpBinding>
        </bindings>
        <client>
            <endpoint address="https://0300555450-hoadon.petrolimex.com.vn/portalservice.asmx"
                binding="basicHttpBinding" bindingConfiguration="PortalServiceSoap"
                contract="portalservice.PortalServiceSoap" name="PortalServiceSoap" />
            <endpoint address="https://0300555450-hoadon.petrolimex.com.vn/BusinessService.asmx"
                binding="basicHttpBinding" bindingConfiguration="BusinessServiceSoap"
                contract="BusinessService.BusinessServiceSoap" name="BusinessServiceSoap" />
            <endpoint address="https://0300555450-hoadon.petrolimex.com.vn/publishservice.asmx"
                binding="basicHttpBinding" bindingConfiguration="PublishServiceSoap"
                contract="publishservice.PublishServiceSoap" name="PublishServiceSoap" />
        </client>
    </system.serviceModel>
</configuration>
