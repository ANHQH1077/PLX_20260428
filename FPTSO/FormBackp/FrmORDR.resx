  <data name="U_ShpCod.SQL_String" xml:space="preserve">
    <value>select c.Code , Name  from [FPTSHOP] c  with (nolock) , SYS_USER_SHOP d  where c.Code = case when ISNULL(d.ShpCode ,'')='ALL' then c.Code else  d.ShpCode end and d.USER_ID =:U_UserLogin and U_ComCode=:ComCodeKey</value>
