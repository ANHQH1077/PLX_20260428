  <data name="U_PriLis.SQL_String" xml:space="preserve">
    <value>select distinct DocNum, U_ListName  from [FPTOPLN1] A  with (nolock), [FPTITM12] B   with (nolock) where a.docentry=b.DocEntry and exists (select 1  from [FPTSHOP] c, SYS_USER_SHOP d  where c.Code = case when ISNULL(d.ShpCode ,'')='ALL' then c.Code else  d.ShpCode end ) and :U_ShpCod=case when isnull(U_ShpCod,'ALL')='ALL' then :U_ShpCod else U_ShpCod end</value>
  </data>
