  <data name="MaHangHoa.SQLString" xml:space="preserve">
    <value>select MaHangHoa, TenHangHoa  from tblHangHoa a where  (Status='X' and exists (select 1 from  tblProject_Details b where a.MaHangHoa = case when isnull( :SoHopDong ,'') = ''  then a.MaHangHoa else b.Matnr end and Vbeln =case when  isnull( :SoHopDong ,'') ='' then Vbeln  else :SoHopDong end)) or (select count(*) from tblProjects ) &lt;=0</value>
  </data>
