    <value>select MENU_NAME, MENU_ID, DESCRIPTION from SYS_MENU WHERE CONVERT(date,getdate())&gt;= CONVERT(date,ISNULL(from_date,getdate())) and CONVERT(date,getdate())&lt;= CONVERT(date,ISNULL(to_date,getdate())) and UPPER( MENU_CODE)&lt;&gt;'MNUHT'</value>
